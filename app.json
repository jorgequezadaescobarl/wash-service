{
  "expo": {
    "name": "Pristine",
    "slug": "pristine",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pristine",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pristine.app"
    },
    "android": {
      "package": "com.pristine.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
